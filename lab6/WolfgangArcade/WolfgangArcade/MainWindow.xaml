<Window x:Class="Wolfenstein3DClone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DUNGEON WALKER" Height="720" Width="920"
        Background="Black"
        KeyDown="Window_KeyDown"
        Focusable="True">

    <Window.Resources>
        <Style x:Key="PixelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="0" ShadowDepth="2" Opacity="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="300"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.9"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="FontSize" Value="22"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ==================== AUDIO PLAYERS ==================== -->
        <MediaElement x:Name="MenuMusicPlayer" 
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      MediaEnded="MenuMusicPlayer_MediaEnded"
                      Visibility="Hidden"/>
        <MediaElement x:Name="LevelMusicPlayer" 
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      MediaEnded="LevelMusicPlayer_MediaEnded"
                      Visibility="Hidden"/>
        <MediaElement x:Name="HellMusicPlayer" 
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      MediaEnded="HellMusicPlayer_MediaEnded"
                      Visibility="Hidden"/>
        <MediaElement x:Name="DeathMusicPlayer" 
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      Visibility="Hidden"/>
        <MediaElement x:Name="StepSound" 
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      Visibility="Hidden"/>

        <!-- ==================== FAKE LOADING SCREEN ==================== -->
        <Grid x:Name="LoadingScreen" Visibility="Hidden" Background="#0a0a14">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="LoadingText" 
                           Text="СТРОИМ СТЕНЫ..." 
                           FontFamily="Courier New" FontWeight="Bold" 
                           FontSize="36" Foreground="#aaaaaa"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="0" ShadowDepth="2" Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- ==================== MAIN MENU ==================== -->
        <Grid x:Name="MainMenu">
            <Image Source="Assets/menu_bg.png" Stretch="Fill"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="DUNGEON" 
                           FontFamily="Courier New" FontWeight="Bold" 
                           FontSize="56" Foreground="#cc0000"
                           HorizontalAlignment="Center" Margin="0,0,0,-10">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Red" BlurRadius="15" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <TextBlock Text="WALKER" 
                           FontFamily="Courier New" FontWeight="Bold" 
                           FontSize="56" Foreground="#cc0000"
                           HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Red" BlurRadius="15" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- difficulty selection -->
                <TextBlock Text="СЛОЖНОСТЬ:" 
                           FontFamily="Courier New" FontWeight="Bold" 
                           FontSize="16" Foreground="#aaaaaa"
                           HorizontalAlignment="Center" Margin="0,5,0,5"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <Button x:Name="BtnEasy" Content="🌿 ЛЁГКАЯ"
                            Style="{StaticResource MenuButton}"
                            Background="#335533" Width="72" Height="35" FontSize="11"
                            Click="BtnEasy_Click" Margin="0,0,3,0"/>
                    <Button x:Name="BtnNormal" Content="⚡ НОРМА"
                            Style="{StaticResource MenuButton}"
                            Background="#888833" Width="72" Height="35" FontSize="11"
                            Click="BtnNormal_Click" Margin="0,0,3,0"/>
                    <Button x:Name="BtnHard" Content="💀 ХАРД"
                            Style="{StaticResource MenuButton}"
                            Background="#553333" Width="72" Height="35" FontSize="11"
                            Click="BtnHard_Click" Margin="0,0,3,0"/>
                    <Button x:Name="BtnHell" Content="🔥 АД"
                            Style="{StaticResource MenuButton}"
                            Background="#330000" Width="72" Height="35" FontSize="11"
                            Click="BtnHell_Click" Foreground="#ff4444"/>
                </StackPanel>

                <!-- level buttons -->
                <Button x:Name="BtnRandom" Content="🎲 Случайный уровень"
                        Style="{StaticResource MenuButton}"
                        Background="#333366"
                        Click="BtnRandom_Click" Margin="0,10,0,10" Width="329"/>
                <Button x:Name="BtnLevel1" Content="🏰 Подземелье замка"
                        Style="{StaticResource MenuButton}"
                        Background="#334466"
                        Click="BtnLevel1_Click" Width="329"/>
                <Button x:Name="BtnLevel2" Content="🕯️ Склеп"
                        Style="{StaticResource MenuButton}"
                        Background="#334466"
                        Click="BtnLevel2_Click" Width="329"/>
                <Button x:Name="BtnLevel3" Content="💎 Сокровищница"
                        Style="{StaticResource MenuButton}"
                        Background="#334466"
                        Click="BtnLevel3_Click" Width="330"/>
                <Button x:Name="BtnEndless" Content="🔄 Бесконечное подземелье"
                        Style="{StaticResource MenuButton}"
                        Background="#334466"
                        Click="BtnEndless_Click" Width="329"/>
                <Button x:Name="BtnExit" Content="⬅️ ВЫХОД"
                        Style="{StaticResource MenuButton}"
                        Background="#442222"
                        Click="BtnExit_Click" Width="329"/>

                <TextBlock Text="СТРЕЛКИ / WASD - ДВИЖЕНИЕ  |  ESC - МЕНЮ  |  R - РЕСТАРТ"
                           FontFamily="Courier New" FontSize="13"
                           Foreground="#aaaaaa"
                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ==================== DEATH MENU ==================== -->
        <Grid x:Name="DeathMenu" Visibility="Hidden">
            <Image Source="Assets/death_bg.png" Stretch="Fill"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="💀 ВЫ ПОГИБЛИ!" 
                           FontFamily="Courier New" FontWeight="Bold" 
                           FontSize="52" Foreground="#cc0000"
                           HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Red" BlurRadius="15" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Button x:Name="BtnRestart" Content="🔄 ПЕРЕЗАПУСТИТЬ УРОВЕНЬ"
                        Style="{StaticResource MenuButton}"
                        Background="#444433"
                        Click="BtnRestart_Click"/>
                <Button x:Name="BtnDeathToMenu" Content="🏠 ГЛАВНОЕ МЕНЮ"
                        Style="{StaticResource MenuButton}"
                        Background="#443333"
                        Click="BtnDeathToMenu_Click"/>

                <TextBlock Text="R - ПЕРЕЗАПУСК  |  ESC - ГЛАВНОЕ МЕНЮ"
                           FontFamily="Courier New" FontSize="13"
                           Foreground="#aaaaaa"
                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ==================== GAME CANVAS ==================== -->
        <Canvas x:Name="GameCanvas" 
                Width="760" Height="600"
                Margin="10,60,10,10"
                Background="#0a0a14"
                ClipToBounds="True"
                Visibility="Hidden">
        </Canvas>

        <!-- ==================== HUD ==================== -->
        <StackPanel x:Name="HudPanel" Orientation="Horizontal" 
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="10,10,0,0"
                    Visibility="Hidden">
            <TextBlock x:Name="ScoreText" 
                       Text="СОКРОВИЩ: 0 / 5" 
                       Style="{StaticResource PixelText}"
                       Foreground="#ffdd00" FontSize="20"
                       Margin="0,0,30,0"/>
            <TextBlock x:Name="LivesText" 
                       Text="ЖИЗНИ: ♥♥♥" 
                       Style="{StaticResource PixelText}"
                       Foreground="#ff4444" FontSize="20"
                       Margin="0,0,30,0"/>
            <TextBlock x:Name="LevelText" 
                       Text="УРОВЕНЬ: 1" 
                       Style="{StaticResource PixelText}"
                       Foreground="#4488ff" FontSize="20"/>
            <TextBlock x:Name="HellLabel" 
                       Text="🔥 АД 🔥" 
                       Style="{StaticResource PixelText}"
                       Foreground="#ff2222" FontSize="18"
                       Visibility="Hidden" Margin="20,0,0,0"/>
            <TextBlock x:Name="MessageText" 
                       Text="" 
                       Style="{StaticResource PixelText}"
                       Foreground="#888888" FontSize="14"
                       Margin="40,4,0,0"/>
        </StackPanel>

        <Border BorderBrush="#333355" BorderThickness="2" CornerRadius="5" 
                Margin="8" IsHitTestVisible="False"/>
    </Grid>
</Window>